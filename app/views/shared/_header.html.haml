%header
  %ul
    %li= link_to t('header.home'), root_path
    %li= link_to t('header.contacts'), main_contacts_path
    %li= link_to t('header.help'), main_help_path
    %li= link_to t('header.about'), main_about_path
    - if signed_in?
      %li= link_to t('header.results'), results_list_path
      %li= link_to t('header.sign_out'), signout_path
      %li.logged
        = current_user.email
        %img{ src: "https://secure.gravatar.com/avatar/#{Digest::MD5.hexdigest(current_user.email)}.png", style: "width: 25px;" }
    - else
      %li= link_to t('header.sign_in'), signin_path

  .locale
    .ru_link
      = link_to image_tag("rus.png", alt: "", style: "width: 30px; margin-right: 5px", title: t('header.ru_title', default: "Русский")), locale: :ru
    .en_link
      = link_to image_tag("en.png", alt: "", style: "width: 30px; margin-right: 5px", title: t('header.en_title', default: "English")), locale: :en
    %b
      = I18n.locale